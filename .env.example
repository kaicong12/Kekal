# Email Service Configuration
# Copy this file to .env.local and fill in your email credentials

# Gmail Configuration (recommended for development)
EMAIL_USER=your-email@gmail.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Default sender information
DEFAULT_FROM_EMAIL=noreply@kekal.com
DEFAULT_FROM_NAME=Kekal Team

# Admin email for receiving contact forms and notifications (your email)
ADMIN_EMAIL=kaicong12@gmail.com
